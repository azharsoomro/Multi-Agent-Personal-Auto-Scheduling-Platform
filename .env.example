# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:latest

# ── Email (Gmail SMTP with App Password) ─────────────────────────────────────
# Enable 2FA on your Google account, then create an App Password at:
# https://myaccount.google.com/apppasswords
EMAIL_ADDRESS=yourname@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_RECIPIENT=yourname@gmail.com

# ── YouTube Data API v3 ───────────────────────────────────────────────────────
# Get a free key at: https://console.cloud.google.com/
# Leave blank to run AI-Times in demo mode (mock data)
YOUTUBE_API_KEY=

# ── Gmail OAuth (Mailman agent) ───────────────────────────────────────────────
# Download credentials.json from Google Cloud Console (OAuth 2.0 Desktop app)
# Leave blank to run Mailman in demo mode (classifies mock emails)
GMAIL_CREDENTIALS_FILE=gmail_credentials.json
GMAIL_TOKEN_FILE=data/gmail_token.json

# ── Agent schedules (cron: minute hour day month weekday) ─────────────────────
SCHEDULE_AI_TIMES=0 8 * * *
SCHEDULE_MAILMAN=*/15 * * * *
SCHEDULE_WALLSTREET=30 16 * * 1-5
SCHEDULE_HACKER_DIGEST=0 9 * * *

# ── Resource thresholds (% — agents pause if exceeded) ───────────────────────
CPU_THRESHOLD_PCT=85
RAM_THRESHOLD_PCT=85
DISK_THRESHOLD_PCT=90

# ── Stock tickers (comma-separated, no spaces) ────────────────────────────────
STOCK_TICKERS=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,AMD,INTC,ORCL,NFLX,PYPL,CRM,SHOP,SQ,COIN,PLTR,ARM,SMCI,TSM,ASML,QCOM,AVGO,MU,AMAT
